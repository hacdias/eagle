<nav id='navbar' class='full-width'>
  <input type="checkbox" id="toggler">
  <ul>
    <label for="toggler"><a class='no-link'>🍔 Menu</a></label>
    {{ range .Site.Menu -}}
      <li>
        <a href='{{ relURL $ .URL }}' class='no-link'>
          <span>{{ .Name }}</span>
        </a>
      </li>
    {{ end }}
  </ul>
</nav>