{{- $description := or .Description .Site.Description }}
{{- $shortTitle := or .Title .Site.Title -}}
{{- $longTitle := (printf "%s - %s" $shortTitle .Site.Title) -}}
{{- if .IsHome -}}{{ $longTitle = .Site.Title }}{{- end -}}
{{- if not .Title -}}{{ $longTitle = $shortTitle }}{{- end -}}

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="canonical" href="{{ .Permalink }}">
<title>{{ $longTitle }}</title>
<meta name="description" content="{{ $description }}">

<link rel="icon" href="{{ relURL . "/favicon.ico" }}" type=image/x-icon>
{{ if .NoIndex }}
 <meta name="robots" content="noindex">
{{ end }}

<!-- Social Media -->
<meta name="twitter:site" content="@{{ .Site.Author.Username }}"/>
<meta name="twitter:creator" content="@{{ .Site.Author.Username }}"/>
<meta property="og:locale" content="en" />
<meta property="og:title" content="{{ $shortTitle }}" />
<meta property="og:description" content="{{ $description }}" />
<meta property="og:site_name" content="{{ .Site.Title }}" />

{{- if not .PublishDate.IsZero -}}
  <meta property="article:published_time" content="{{ .PublishDate.Format "2006-01-02T15:04:05-07:00" }}" />
{{- end -}}

{{- if not .UpdateDate.IsZero -}}
  {{ $UpdateDate := .Date.Format "2006-01-02T15:04:05-07:00" }}
  <meta property="article:modified_time" content="{{ $UpdateDate }}" />
  <meta property="og:updated_time" content="{{ $UpdateDate }}" />
{{- end -}}

<!-- OpenID delegation -->
<link rel="openid.delegate" href="https://hacdias.com/" />
<link rel="openid.server" href="https://openid.indieauth.com/openid" />

<!-- IndieAuth.me Methods -->
<link rel="me" href="https://twitter.com/hacdias" />
<link rel="me" href="https://github.com/hacdias" />
<link rel="me" href="https://facebook.com/hacdias" />
<link rel="me" href="https://instagram.com/hacdias" />
<link rel="me" href="https://keybase.io/hacdias" />
<link rel="me" href="https://linkedin.com/in/hacdias" />
<link rel="me" href="mailto:mail@hacdias.com" />
<link rel="me" href="https://micro.blog/hacdias" />
<link rel="me" href="https://news.ycombinator.com/user?id=hacdias" />
<link rel="me" href="https://lobste.rs/u/hacdias" />
<link rel="me" href="https://hacdias.com/pubkey.txt" rel="pgpkey" />

<link rel="webmention" href="https://webmention.io/hacdias.com/webmention" />
<link rel="pingback" href="https://webmention.io/hacdias.com/xmlrpc" />

{{ if .IsHome }}
  <link rel="feed" href="https://hacdias.com/all" />
  <link rel="authorization_endpoint" href="https://indieauth.com/auth" />
  <link rel="token_endpoint" href="https://tokens.indieauth.com/token" />
  <link rel="micropub" href="https://hacdias.com/micropub" />
  <link rel="microsub" href="https://aperture.p3k.io/microsub/455" />
{{ end }}
